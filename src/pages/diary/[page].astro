---
import { getCollection } from 'astro:content';
import BlogLayout from '../../layouts/BlogLayout.astro';

export async function getStaticPaths({ paginate }) {
  const allEntries = await getCollection('diary');
  
  const entriesWithContentPromises = allEntries.map(async (entry) => {
    const { Content } = await entry.render();
    
    return { ...entry, Content }; 
  });

  const entriesWithContent = await Promise.all(entriesWithContentPromises);

  const sortedEntries = entriesWithContent
    .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
    
  return paginate(sortedEntries, { 
    pageSize: 10,
  });
}

const { page } = Astro.props;

const allBlogPosts = await getCollection('blog');
const allGenres = allBlogPosts
  .map(post => post.data.genres || []) 
  .flat(); 

const uniqueGenres = [...new Set(allGenres)]; 
const sortedGenres = uniqueGenres.sort((a, b) => a.localeCompare(b));

const title = `diary ⟢ page ${page.currentPage}`;

const formatDate = (date) => {
  return new Date(date).toLocaleDateString('en-US', { year:'numeric', month: 'long', day: "numeric" });
}
---

<BlogLayout title={title} genres={sortedGenres}>
  <section class="content-area" id="diary-list">
    <img
      src={"https://64.media.tumblr.com/41a6268bd7717b65193cf30260e6408d/3e3ee5631cb7fc6c-02/s1280x1920/03a1da60b74f5d481d0afa069d607c2eaa284de0.png"}
      alt="hi"
      class="home-page-image"
    />

    
    {page.data.map((entry) => (
        <article class="diary-summary">
            <h2>
                <a href={`/diary/${entry.slug}`}>{entry.data.title}</a>
            </h2>
            <p class="entry-meta">
                By <strong>{entry.data.author || '???'}</strong> |
                Date: {formatDate(entry.data.date)} |
                Mood: {entry.data.mood || 'N/A'}
            </p>
            <hr />
            
            <div class="diary-content-preview">
                <entry.Content />
            </div>
        </article>
    ))}

    <div class="pagination-nav">
        {page.url.prev && (
            <a href={page.url.prev} class="prev-link">← Previous Page</a>
        )}
        {page.url.next && (
            <a href={page.url.next} class="next-link">Next Page →</a>
        )}
    </div>
  </section>
</BlogLayout>