---
import '@fortawesome/fontawesome-free/css/all.min.css';
import { getCollection } from 'astro:content';
import "../styles/blog.css"; 
import "../styles/socials.css"; 
import SocialsLayout from '../layouts/SocialsLayout.astro'; 

// --- Data Fetching Logic ---

const allBlogEntries = await getCollection('blog');
const blogGenres = [...new Set(
  allBlogEntries
    .flatMap(e => e.data.genres || [])
    .filter(Boolean)
)].sort((a, b) => a.localeCompare(b));

const pageSize = 5; 
const sortedPosts = allBlogEntries
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const posts = sortedPosts.slice(0, pageSize);


const nextPage = sortedPosts.length > pageSize ? `/blog/2` : null;

// --- Helper Functions ---

const formatDate = (date) => {
  const options = {
    year:'numeric',
    month: 'long',
    day: "numeric"
  };
  return new Date(date).toLocaleDateString('en-US', options);
}

// --- Component Props ---
const title = "postdog ⟢ links";
---

<SocialsLayout title={title} genres={blogGenres}>
