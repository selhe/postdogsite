---
// src/pages/index.astro

import { getCollection } from 'astro:content';
// Ensure the path to your styles is correct
import "../styles/blog.css"; 
// Use the layout that contains your sidebar and genre navigation
import BlogLayout from '../layouts/BlogLayout.astro'; 

// --- Data Fetching Logic ---

// 1. Fetch ALL posts to calculate the global genre list for the sidebar
const allBlogEntries = await getCollection('blog');
const blogGenres = [...new Set(
  allBlogEntries
    .flatMap(e => e.data.genres || [])
    .filter(Boolean)
)].sort((a, b) => a.localeCompare(b));

// 2. Paginate the data manually for the first page only
const pageSize = 5; // Must match the pageSize in blog/[page].astro
const sortedPosts = allBlogEntries
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

// Get the posts for the first page
const posts = sortedPosts.slice(0, pageSize);

// Calculate pagination URLs for the sidebar's "Show All" link
// Since this is page 1, the 'prev' link is null.
const nextPage = sortedPosts.length > pageSize ? `/blog/2` : null;

// --- Helper Functions ---

const formatDate = (date) => {
  const options = {
    year:'numeric',
    month: 'long',
    day: "numeric"
  };
  return new Date(date).toLocaleDateString('en-US', options);
}

// --- Component Props ---
const title = "postdog";
---

<BlogLayout title={title} genres={blogGenres}>
  <div id="gif-intro-overlay">
    <img src="https://i.pinimg.com/originals/5f/3f/e7/5f3fe747692cc78be5fc34bf7d7c2fbc.gif" id="intro-gif" alt="Website Intro Animation">
  </div>
  <div id="main-content">
  <section class="content-area" id="posts">
    <img
      src={"https://64.media.tumblr.com/41a6268bd7717b65193cf30260e6408d/3e3ee5631cb7fc6c-02/s1280x1920/03a1da60b74f5d481d0afa069d607c2eaa284de0.png"}
      alt="hi"
      class="home-page-image"
    />
    <div class="site-introduction">
        <h1>ʌɐʍ˙ƃoptsod</h1>
        <p>We Maʞe Musᴉc.</p>
        <p>Feel Free to Browse Our Archᴉves.</p>
    </div>
    
    <img
      src={"https://pbs.twimg.com/media/Gqe2ILUXgAAvYea?format=jpg&name=4096x4096"} 
      alt="hi"
      class="blog-intro-image"
    />
    
    {posts.map((post) => (
      <article 
        data-genres={(post.data.genres || []).join(",")} 
        data-slug={post.slug}
      >
        <h3>
          <a href={`/blog/${post.slug}`}>{post.data.title}</a>
        </h3>

        {post.data.albumCover && (
          <div class="thumbnail-container">
            <img
              src={post.data.albumCover}
              alt={`Album cover for ${post.data.title}`}
              class="album-thumbnail"
            />
          </div>
        )}
        <p>{post.data.description}</p>
        <div class="post-meta">
          Posted by
          <strong>{post.data.author || 'Anonymous'}</strong> on
          {formatDate(post.data.date)} |
          {post.data.comments || 0} comments
          
          <span class="labels">
            Labels:
            {post.data.genres && post.data.genres.length > 0 ? post.data.genres.map(genre => (
              <span class="genre-tag">{genre}</span>
            ))
            : 'none'}
          </span>
        </div> 
      </article>
    ))}
    
    <div class="pagination-nav">
      {/* {prevPage && (
        <a href={prevPage} class="prev-link">← Previous Page</a>
      )} */}

      {nextPage && (
        <a href={nextPage} class="next-link">Next Page →</a>
      )}
    </div>
  </section>
  </div>
  <script src="/javascript/intro-animation.js" is:inline></script>
</BlogLayout>