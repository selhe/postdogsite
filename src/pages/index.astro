---
import { getCollection } from 'astro:content';
import "../styles/blog.css"; 
import BlogLayout from '../layouts/BlogLayout.astro'; 

const allBlogEntries = await getCollection('blog');
const blogGenres = [...new Set(
  allBlogEntries
    .flatMap(e => e.data.genres || [])
    .filter(Boolean)
)].sort((a, b) => a.localeCompare(b));


const allDiaryEntries = await getCollection('diary');

const entriesWithContentPromises = allDiaryEntries.map(async (entry) => {
  const { Content } = await entry.render();
  return { ...entry, Content }; 
});

const allRenderedDiaryEntries = await Promise.all(entriesWithContentPromises);

const pageSize = 10; 
const sortedDiaryEntries = allRenderedDiaryEntries
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const diaryPosts = sortedDiaryEntries.slice(0, pageSize);

const nextPage = sortedDiaryEntries.length > pageSize ? `/diary/2` : null;

// --- Helper Functions ---

const formatDate = (date) => {
  const options = {
    year:'numeric',
    month: 'long',
    day: "numeric"
  };
  return new Date(date).toLocaleDateString('en-US', options);
}

const title = "Postdog Diary";
---

<BlogLayout title={title} genres={blogGenres}>
  <head>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" crossorigin="anonymous">
  </head>
  <div id="gif-intro-overlay">
    <img src="https://favim.com/pd/s12/gif_previews/8/896/8964/89641/8964147.gif" id="intro-gif" alt="Website Intro Animation">
  </div>
  <div id="main-content">
  <section class="content-area" id="diary-posts">
    <img
      src={"https://64.media.tumblr.com/41a6268bd7717b65193cf30260e6408d/3e3ee5631cb7fc6c-02/s1280x1920/03a1da60b74f5d481d0afa069d607c2eaa284de0.png"}
      alt="hi"
      class="home-page-image"
    />
    <div class="site-introduction">
        <h1>postdog</h1>
        <p>We Maʞe Musᴉc.</p>
        <p>Lᴉnʞed Socᴉals Below.</p>
    </div>

    <section class="social-icons">
      <a href="https://postdog.bandcamp.com/" target="_blank" rel="noopener noreferrer" title="Listen on Bandcamp">
        <i class="fab fa-bandcamp"></i>
      </a>
      <a href="https://open.spotify.com/artist/36sH7WuE3rK3YmlSLiFmYo?si=QT52jfo4QWmado0pJNLgsA" target="_blank" rel="noopener noreferrer" title="Stream on Spotify">
        <i class="fab fa-spotify"></i>
      </a>
      <a href="https://music.apple.com/us/artist/postdog/1870476310" target="_blank" rel="noopener noreferrer" title="Listen on Apple Music">
        <i class="fab fa-apple"></i>
      </a>
      <a href="https://www.youtube.com/@postdogband" target="_blank" rel="noopener noreferrer" title="Watch on YouTube">
        <i class="fab fa-youtube"></i>
      </a>
      <a href="https://www.instagram.com/postdogband" target="_blank" rel="noopener noreferrer" title="Follow on Instagram">
        <i class="fab fa-instagram"></i>
      </a>
      <a href="/contact" rel="noopener noreferrer" title="Email">
        <i class="fas fa-envelope"></i>
      </a>
      <a href="/love" rel="noopener noreferrer" title="nothing">
        <i class="fa-regular fa-heart"></i>
      </a>
    </section>
    
    <img
      src={"https://pbs.twimg.com/media/Gqe2ILUXgAAvYea?format=jpg&name=4096x4096"} 
      alt="hi"
      class="blog-intro-image"
    />
    
    {diaryPosts.map((entry) => (
      <article class="diary-summary"
        data-slug={entry.slug}
      >
        <h2>
          <a href={`/diary/${entry.slug}`}>{entry.data.title}</a>
        </h2>
        <p class="entry-meta">
            By <strong>{entry.data.author || '???'}</strong> |
            Date: {formatDate(entry.data.date)} |
            Mood: {entry.data.mood || 'N/A'}
        </p>
        <hr />
        
        {/* Renders the full content preview of the diary entry */}
        <div class="diary-content-preview">
            <entry.Content />
        </div>
      </article>
    ))}
    
    <div class="pagination-nav">
      {/* Since this is the index page, we only show the link to the next page of the diary */}
      {nextPage && (
        <a href={nextPage} class="next-link">Next Page →</a>
      )}
    </div>
  </section>
  </div>
  <script src="/javascript/intro-animation.js" is:inline></script>
</BlogLayout>