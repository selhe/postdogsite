---
import "../styles/global.css"; 
---

<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>RECOVERY_TERMINAL</title>
    <link rel="icon" href="/favicon/favicon.ico?v=2" />
    <style>
        :root {
            --dirt: #1a1a1a;
            --rust: #1d1a5e;
            --decay: #3d3d29;
            --ghost-white: #c4c4c4;
        }

        body {
            background-color: #0a0a0a;
            color: var(--ghost-white);
            margin: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            height: 100vh;
            overflow: hidden;
            font-family: 'Courier New', monospace;
        }

        /* Ambient Fog/Static Overlay */
        .overlay {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: url('https://media3.giphy.com/media/v1.Y2lkPWVjZjA1ZTQ3Z2F3ZHp4d283MmxqMTNicGpkMmN0c3lvOHI0ZnJ2cnFkbWJ4MDN2ciZlcD12MV9naWZzX3JlbGF0ZWQmY3Q9Zw/MXLEY4XSnHqcAlbAQk/200.webp');
            opacity: 0.05;
            pointer-events: none;
            z-index: 10;
        }

        /* The Box of Decay */
        .terminal-box {
            width: 100%;
            max-width: 400px;
            padding: 40px;
            background: linear-gradient(135deg, #111 0%, #050505 100%);
            border: 1px solid var(--rust);
            box-shadow: 0 0 30px rgba(0,0,0,1), inset 0 0 100px rgba(94, 38, 26, 0.1);
            position: relative;
            z-index: 5;
        }

        .terminal-box::before {
            content: "";
            position: absolute;
            top: 0; left: 0; width: 100%; height: 2px;
            background: var(--rust);
            box-shadow: 0 0 10px var(--rust);
            animation: scanline 6s linear infinite;
        }

        h1 {
            font-size: 14px;
            text-transform: uppercase;
            letter-spacing: 4px;
            color: var(--rust);
            margin-bottom: 40px;
            text-align: center;
        }

        .input-wrap {
            margin-bottom: 25px;
            position: relative;
        }

        label {
            font-size: 10px;
            display: block;
            margin-bottom: 8px;
            color: var(--decay);
        }

        input {
            width: 100%;
            background: transparent;
            border: 1px solid #222;
            padding: 12px;
            color: #888;
            font-family: inherit;
            outline: none;
            transition: all 0.4s;
        }

        input:focus {
            border-color: var(--rust);
            color: var(--ghost-white);
            box-shadow: 0 0 10px rgba(94, 38, 26, 0.3);
        }

        button {
            width: 100%;
            padding: 15px;
            background: transparent;
            border: 1px solid var(--rust);
            color: var(--rust);
            cursor: pointer;
            font-family: inherit;
            font-size: 12px;
            text-transform: uppercase;
            transition: 0.3s;
        }

        button:hover {
            background: var(--rust);
            color: black;
            box-shadow: 0 0 20px var(--rust);
        }

        .status-msg {
            margin-top: 30px;
            font-size: 9px;
            color: #333;
            text-align: center;
            line-height: 1.6;
        }

        @keyframes scanline {
            0% { top: 0; }
            100% { top: 100%; }
        }

        /* Cracks/Vignette */
        .vignette {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            box-shadow: inset 0 0 150px black;
            pointer-events: none;
            z-index: 11;
        }
    </style>
</head>
<body>
    <div class="overlay"></div>
    <div class="vignette"></div>

    <div class="terminal-box">
        <h1>ƎפH∀ԀO┴NIפO˥</h1>
        
        <form>
            <div class="input-wrap">
                <label>iten ewe poraus</label>
                <input type="text" spellcheck="false" />
            </div>

            <div class="input-wrap">
                <label>kii seken</label>
                <input type="password" />
            </div>

            <button type="button">bG9naW4</button>
        </form>

        <div class="status-msg">
            BUDBCYBADFsl9C3u0TEODPiwJzQBcfsSuVE/mvJDCVdzlQ4kRML3Mvx++4wB
        </div>
    </div>
</body>
</html>